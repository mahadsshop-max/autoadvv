# Copy this file to ".env" and fill in your values.
# Anything left blank falls back to a safe default where one exists.

# litecoin payments
# The address that receives customer payments.
OWNER_LTC_ADDRESS=

# The BIP39 seed phrase used to derive per-payment deposit addresses.
# Either name works; WALLET_MNEMONIC is checked first.
WALLET_MNEMONIC=
# LTC_SEED_PHRASE=

# discord oauth (login)
CLIENT_ID=
CLIENT_SECRET=
CALLBACK_URL=http://localhost:3000/auth/discord/callback

# app / session
# Your Discord user id (grants owner/admin access). Defaults to the built-in owner.
OWNER_ID=
SESSION_SECRET=change-me-to-a-long-random-string
PORT=3000

# database (optional)
# Without DATABASE_URL the app still runs, but data is not persisted.
DATABASE_URL=
# Set PGSSL=false for a local Postgres without SSL.
# PGSSL=false

# optional
# PURCHASE_WEBHOOK_URL=
